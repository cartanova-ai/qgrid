{
  "name": "qgrid-api",
  "version": "0.0.1",
  "description": "Sonamu API server",
  "license": "MIT",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev": "sonamu dev",
    "build": "sonamu build",
    "postinstall": "sonamu skills sync",
    "start": "sonamu start",
    "test": "vitest run",
    "test:watch": "vitest watch --standalone",
    "test:coverage": "vitest run --coverage",
    "sonamu": "sonamu",
    "dump": "bash database/scripts/dump.sh",
    "seedOnly": "bash database/scripts/seed.sh",
    "seed": "pnpm seedOnly && sonamu fixture sync",
    "sync:dump": "pnpm seed && pnpm sonamu migrate run && pnpm dump",
    "docker:up": "docker compose --env-file .env -f database/docker-compose.yml up -d",
    "docker:down": "docker compose --env-file .env -f database/docker-compose.yml down"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.0",
    "@ai-sdk/openai": "^3.0.0",
    "@ai-sdk/provider": "^3.0.0",
    "@ai-sdk/provider-utils": "^4.0.0",
    "@anthropic-ai/sdk": "^0.81.0",
    "@logtape/logtape": "2.0.0",
    "@logtape/pretty": "2.0.0",
    "@logtape/redaction": "2.0.0",
    "ai": "^6.0.1",
    "bcrypt": "^6.0.0",
    "better-auth": "^1.6.0",
    "chalk": "^4.1.2",
    "date-fns": "^4.1.0",
    "dotenv": "^16",
    "knex": "^3.1.0",
    "pg": "^8.16.3",
    "radashi": "^12.2.0",
    "sonamu": "^0.9.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@fastify/compress": "^7.0.3",
    "@iconify-json/lucide": "catalog:",
    "@types/bcrypt": "^6",
    "@types/node": "25.0.7",
    "@vitest/coverage-v8": "^4.0.12",
    "fastify": "^4",
    "ioredis": "^5.8.2",
    "typescript": "^6.0.0",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
