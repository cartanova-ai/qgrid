{
  "name": "@cartanova/qgrid-sdk",
  "version": "1.3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/cartanova-ai/qgrid"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
